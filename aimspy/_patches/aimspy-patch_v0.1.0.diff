@@ -0,0 +1,93 @@
+module aimspy_api_bank
+
+    use iso_c_binding
+    use mpi_utilities
+    use mpi_tasks
+    use aimspy_callback, only: TAimspyCallback
+    implicit none
+
+    logical :: aimspy_initialized = .false.
+    logical :: aimspy_converged_scf = .false.
+
+    real*8, allocatable, target, save :: c_hamiltonian(:, :)
+    real*8, allocatable, target, save :: c_overlap(:)
+
+    type(TAimspyCallback) :: aimspy_callback_hd
+
+contains
+
+  function c_f_string(c_str) result(f_str)
+    use, intrinsic :: iso_c_binding, only: c_ptr, c_f_pointer, c_char, c_size_t
+    type(c_ptr), intent(in) :: c_str
+    character(:, kind=c_char), pointer :: f_str
+    character(kind=c_char), pointer :: arr(:)
+
+    interface
+      function strlen(s) bind(c, name='strlen')
+        use, intrinsic :: iso_c_binding, only: c_ptr, c_size_t
+        type(c_ptr), intent(in), value :: s
+        integer(c_size_t) :: strlen
+      end function strlen
+    end interface
+
+    call c_f_pointer(c_str, arr, [strlen(c_str)])
+    call get_scalar_pointer(size(arr), arr, f_str)
+  end function c_f_string
+
+
+  subroutine get_scalar_pointer(scalar_len, scalar, ptr)
+    use, intrinsic :: iso_c_binding, only: c_char
+    integer, intent(in) :: scalar_len
+    character(kind=c_char, len=scalar_len), intent(in), target :: scalar(1)
+    character(:, kind=c_char), intent(out), pointer :: ptr
+
+    ptr => scalar(1)
+  end subroutine get_scalar_pointer
+
+  type(c_ptr) function c_rs_hamiltonian() bind(c, name='c_rs_hamiltonian')
+    implicit none
+
+    !write(*, '(A)') "get c_rs_hamiltonian"
+    if (myid==0) then
+      c_rs_hamiltonian = c_loc(c_hamiltonian) 
+    else
+      c_rs_hamiltonian = c_null_ptr
+    end if
+  end function c_rs_hamiltonian
+
+  type(c_ptr) function c_rs_overlap() bind(c, name='c_rs_overlap')
+    implicit none
+
+    !write(*, '(A)') "get c_rs_overlap"
+    if (myid==0) then
+      c_rs_overlap = c_loc(c_overlap) 
+    else
+      c_rs_overlap = c_null_ptr
+    end if
+  end function c_rs_overlap
+
+  real*8 function aimspy_energy() bind(c, name='aimspy_energy')
+    use physics, only: total_energy, post_scf_total_energy
+    implicit none
+
+    if (post_scf_total_energy /= 0.0d0) then
+      aimspy_energy = post_scf_total_energy
+    else
+      aimspy_energy = total_energy
+    end if
+  end function aimspy_energy
+
+  type(c_ptr) function aimspy_forces() bind(c, name='aimspy_forces')
+    use physics, only: total_forces  ! shape (3, natoms) in fortran
+    use dimensions, only: use_forces
+    implicit none
+
+    if (use_forces) then
+      aimspy_forces = c_loc(total_forces)
+    else
+      aimspy_forces = c_null_ptr
+    end if
+
+  end function aimspy_forces
+
+end module aimspy_api_bank
