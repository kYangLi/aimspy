--- /dev/null
+++ b/src/aimspy_api/callback.f90
@@ -0,0 +1,241 @@
+module aimspy_callback
+
+    use iso_c_binding
+    implicit none
+    private
+
+    public :: TAimspyCallback
+    public :: TAimspyCsrMxDescr
+
+
+        type, bind(c) :: TAimspyCsrMxDescr
+            integer(c_int) :: n_basis
+            integer(c_int) :: n_spin
+            integer(c_int) :: n_cells
+            integer(c_int) :: n_ham_size ! nnz + 1
+
+            type(c_ptr)  :: cell_idx     = c_null_ptr  ! cell_index, shape (n_cells, n_coords), n_coords = 3
+            type(c_ptr)  :: row_mx_idx   = c_null_ptr  ! index_hamiltonian, shape (2, n_cells, n_basis)
+            type(c_ptr)  :: col_mx_idx   = c_null_ptr  ! column_index_hamiltonian, shape (n_ham_size)
+        end type TAimspyCsrMxDescr
+
+        type :: TAimspyCallback
+            
+            type(c_ptr), private :: descr_ptr  = c_null_ptr ! TAimspyCsrMxDescr ptr
+
+            ! ============== [1]. callback functions pointers and aux pointers ===========
+            ! get mx descripter
+            type(c_funptr), private :: get_descr_callback = c_null_funptr
+            type(c_ptr), private    :: get_descr_aux_ptr  = c_null_ptr
+
+            ! export H0
+            type(c_funptr), private :: export_h0_callback = c_null_funptr
+            type(c_ptr), private    :: export_h0_aux_ptr  = c_null_ptr
+
+            ! modify H0
+            type(c_funptr), private :: modify_h0_callback = c_null_funptr
+            type(c_ptr), private    :: modify_h0_aux_ptr  = c_null_ptr
+            type(c_ptr), private    :: modify_h0_input_mx_ptr   = c_null_ptr        ! c_ptr of double
+            logical        :: modify_h0_registed = .false.
+
+            ! only python callback
+            type(c_funptr), private :: python_callback = c_null_funptr
+            type(c_ptr), private    :: python_aux_ptr  = c_null_ptr
+
+          contains
+            ! ============== [2]. register methods and calling functins ==================
+            procedure :: register_get_descr
+            procedure :: get_descr_func
+
+            procedure :: register_export_h0
+            procedure :: export_h0_func
+
+            procedure :: register_modify_h0
+            procedure :: modify_h0_func
+
+            procedure :: register_python_callback
+            procedure :: python_func
+
+            ! ========================= end [1]. [2]. ====================================
+
+        end type TAimspyCallback
+
+        ! ============== [3]. interface about the callback c function ==================
+        abstract interface
+            subroutine aimspy_get_descr_cb_t(aux_ptr, descr_ptr) bind(c)
+                use iso_c_binding
+                type(c_ptr), value :: aux_ptr  ! same type as descr but from python
+                type(c_ptr), value :: descr_ptr
+            end subroutine
+        end interface
+
+        abstract interface
+            subroutine aimspy_export_mx_cb_t(aux_ptr, mx_ptr, n_ham_size, n_spin) bind(c)
+                use iso_c_binding
+                type(c_ptr), value :: aux_ptr
+                type(c_ptr), value :: mx_ptr
+                integer(c_int), value :: n_ham_size
+                integer(c_int), value :: n_spin
+            end subroutine
+        end interface
+
+        abstract interface
+            subroutine aimspy_modify_mx_cb_t(aux_ptr, input_mx_ptr, modified_mx_ptr, n_ham_size, n_spin) bind(c)
+                use iso_c_binding
+                type(c_ptr), value :: aux_ptr
+                type(c_ptr), value :: input_mx_ptr
+                type(c_ptr), value :: modified_mx_ptr
+                integer(c_int), value :: n_ham_size
+                integer(c_int), value :: n_spin
+            end subroutine aimspy_modify_mx_cb_t
+        end interface
+
+        abstract interface
+            subroutine aimspy_python_cb_t(aux_ptr) bind(c)
+                use iso_c_binding
+                type(c_ptr), value :: aux_ptr
+            end subroutine aimspy_python_cb_t
+        end interface
+        ! =================== end [3]. ======================================
+
+        type(TAimspyCsrMxDescr), target :: descr_storage
+
+    contains
+            
+            ! ============== [2]. register methods and calling functins ==================
+            subroutine fill_mx_descr(descr)
+                use iso_c_binding
+                use dimensions, only: n_basis, n_spin, n_hamiltonian_matrix_size
+                use pbc_lists, only: n_cells_in_hamiltonian, cell_index, index_hamiltonian, column_index_hamiltonian
+                type(TAimspyCsrMxDescr), intent(inout) :: descr
+
+                descr%n_basis = int(n_basis, c_int)
+                descr%n_spin = int(n_spin, c_int)
+                descr%n_cells = int(n_cells_in_hamiltonian, c_int)
+                descr%n_ham_size = int(n_hamiltonian_matrix_size, c_int)
+
+                descr%cell_idx = c_loc(cell_index(1,1))
+                descr%row_mx_idx = c_loc(index_hamiltonian(1,1,1))
+                descr%col_mx_idx = c_loc(column_index_hamiltonian(1))
+
+            end subroutine fill_mx_descr
+
+            subroutine register_get_descr(this, callback_funptr, aux_ptr)
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                type(c_funptr), value :: callback_funptr
+                type(c_ptr), value :: aux_ptr
+
+                this%get_descr_callback = callback_funptr
+                this%get_descr_aux_ptr = aux_ptr
+
+            end subroutine register_get_descr
+
+            subroutine get_descr_func(this)
+                use iso_c_binding
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                procedure(aimspy_get_descr_cb_t), pointer :: callback_proc
+
+                if (.not. c_associated(this%get_descr_callback)) then
+                    return
+                end if
+
+                if (.not. c_associated(this%descr_ptr)) then
+                    this%descr_ptr = c_loc(descr_storage)
+                end if
+
+                call c_f_procpointer(this%get_descr_callback, callback_proc)
+                call fill_mx_descr(descr_storage)
+                call callback_proc(this%get_descr_aux_ptr, this%descr_ptr)
+
+            end subroutine get_descr_func
+
+            subroutine register_export_h0(this, callback_funptr, aux_ptr)
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                type(c_funptr), value :: callback_funptr
+                type(c_ptr), value :: aux_ptr
+
+                this%export_h0_callback = callback_funptr
+                this%export_h0_aux_ptr = aux_ptr
+
+            end subroutine register_export_h0
+
+            subroutine export_h0_func(this, init_hamiltonian)
+                use iso_c_binding
+                use dimensions, only: n_hamiltonian_matrix_size, n_spin
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                real*8, intent(in), target :: init_hamiltonian(:, :)
+                procedure(aimspy_export_mx_cb_t), pointer :: callback_proc
+
+                if (.not. c_associated(this%export_h0_callback)) then
+                    return
+                end if
+
+                call c_f_procpointer(this%export_h0_callback, callback_proc)
+                call callback_proc(this%export_h0_aux_ptr, &
+                                  c_loc(init_hamiltonian(1,1)), &
+                                  int(n_hamiltonian_matrix_size, c_int), &
+                                  int(n_spin, c_int))
+            end subroutine export_h0_func
+
+            subroutine register_modify_h0(this, callback_funptr, aux_ptr, input_mx_ptr)
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                type(c_funptr), value :: callback_funptr
+                type(c_ptr), value :: aux_ptr
+                type(c_ptr), value :: input_mx_ptr
+
+                this%modify_h0_callback = callback_funptr
+                this%modify_h0_aux_ptr = aux_ptr
+                this%modify_h0_input_mx_ptr = input_mx_ptr
+                this%modify_h0_registed = .true.
+            end subroutine register_modify_h0
+
+            subroutine modify_h0_func(this, init_hamiltonian)
+                use iso_c_binding
+                use dimensions, only: n_hamiltonian_matrix_size, n_spin
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                real*8, intent(inout), target :: init_hamiltonian(:, :)
+                procedure(aimspy_modify_mx_cb_t), pointer :: callback_proc
+
+                if (.not. c_associated(this%modify_h0_callback)) then
+                    return
+                end if
+
+                call c_f_procpointer(this%modify_h0_callback, callback_proc)
+                call callback_proc(this%modify_h0_aux_ptr, &
+                                   this%modify_h0_input_mx_ptr, &
+                                  c_loc(init_hamiltonian(1,1)), &
+                                  int(n_hamiltonian_matrix_size, c_int), &
+                                  int(n_spin, c_int))
+            end subroutine modify_h0_func
+
+            subroutine register_python_callback(this, callback_funptr, aux_ptr)
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                type(c_funptr), value :: callback_funptr
+                type(c_ptr), value :: aux_ptr
+
+                this%python_callback = callback_funptr
+                this%python_aux_ptr = aux_ptr
+            end subroutine register_python_callback
+
+            subroutine python_func(this)
+                use iso_c_binding
+                implicit none
+                class(TAimspyCallback), intent(inout) :: this
+                procedure(aimspy_python_cb_t), pointer :: callback_proc
+
+                if (.not. c_associated(this%python_callback)) then
+                    return
+                end if
+
+                call c_f_procpointer(this%python_callback, callback_proc)
+                call callback_proc(this%python_aux_ptr)
+            end subroutine python_func
+
+end module aimspy_callback
